# =====================================================
# AutoInvite SaaS — Environment Variables Reference
# Copy this file to .env and fill in your values.
# On Replit: set all vars via Secrets (no .env needed).
# =====================================================

# ─── Application ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Security ─────────────────────────────────────
# Generate a strong random value: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-change-me

# ─── PostgreSQL (VPS / Self-hosted) ───────────────
# Option A: Full connection string (preferred)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autoinvite_saas

# Option B: Individual vars (if DATABASE_URL is not set)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=autoinvite_saas
DB_PASSWORD=postgres
DB_PORT=5432

# ─── Chromium / Puppeteer ─────────────────────────
# Set this on Linux VPS to point directly to the browser binary.
# Leave unset to auto-detect via: which chromium / google-chrome
# Example (Debian/Ubuntu): CHROMIUM_PATH=/usr/bin/google-chrome
# Example (NixOS):         CHROMIUM_PATH=/run/current-system/sw/bin/chromium
CHROMIUM_PATH=

# ─── File Storage ─────────────────────────────────
# Root directory for tenant uploads and WhatsApp auth sessions.
# Default: project root (no need to change for most setups).
DATA_DIR=

# ─── Optional Limits ──────────────────────────────
# Max simultaneous WhatsApp browser instances (RAM budget)
MAX_TOTAL_CLIENTS=5
