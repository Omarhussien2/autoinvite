{
  "name": "autoinvite",
  "version": "1.0.0",
  "description": "AutoInvite SaaS — WhatsApp Invitation Automation Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node src/database/init_saas.js",
    "db:migrate": "node src/database/migrate_saas.js",
    "db:seed-admin": "node src/database/seed_admin.js",
    "build:css": "npx tailwindcss -i src/styles/input.css -o public/css/tailwind.css --minify",
    "build:landing": "cd landing-autoinvite && npm install && npm run build",
    "postinstall": "npm run build:css && (npm run build:landing || echo 'Landing page build skipped')",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@replit/connectors-sdk": "^0.3.0",
    "@wppconnect-team/wppconnect": "^1.41.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "connect-pg-simple": "^10.0.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.3",
    "google-translate-api-x": "^10.7.2",
    "i18next": "^26.0.2",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "inquirer": "^13.2.2",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
