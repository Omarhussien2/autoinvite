<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-bold text-gray-900">سجل جهات الاتصال</h2>
            <p class="text-xs text-gray-400 mt-0.5">كل جهات الاتصال التي قمت برفعها ضمن حملاتك</p>
        </div>
        <div class="flex gap-2">
            <button onclick="exportContacts()"
                class="bg-white border border-gray-200 text-gray-600 px-4 py-2 rounded-xl text-xs font-medium hover:bg-gray-50 transition shadow-sm flex items-center gap-2">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M7 10l5 5 5-5M12 15V3" />
                </svg>
                تصدير CSV
            </button>
        </div>
    </div>

    <!-- Add Table ID for export -->
    <script>
        function exportContacts() {
            const rows = document.querySelectorAll('.contact-row');
            if (rows.length === 0) return alert('لا توجد بيانات للتصدير');

            let csv = [];
            // Header
            csv.push(['الاسم', 'رقم الهاتف', 'الحملة', 'الحالة', 'تاريخ الإرسال'].join(','));

            rows.forEach(row => {
                const name = row.querySelector('td:nth-child(1)').innerText.trim();
                const phone = row.querySelector('td:nth-child(2)').innerText.trim();
                const campaign = row.querySelector('td:nth-child(3)').innerText.trim();
                const status = row.querySelector('td:nth-child(4)').innerText.trim();
                const date = row.querySelector('td:nth-child(5)').innerText.trim();
                
                csv.push([`"${name}"`, `"${phone}"`, `"${campaign}"`, `"${status}"`, `"${date}"`].join(','));
            });

            const csvString = csv.join("\n");
            const filename = 'contacts_export_' + new Date().toISOString().slice(0, 10) + '.csv';
            const blob = new Blob(["\ufeff", csvString], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            
            link.setAttribute("href", url);
            link.setAttribute("download", filename);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    </script>

    <!-- Filters -->
    <div class="flex items-center gap-4 mb-6">
        <div class="relative flex-1">
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none"
                stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" id="contact-search" placeholder="ابحث بالاسم أو الرقم"
                class="w-full pr-10 pl-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 bg-gray-50">
        </div>
        <select id="status-filter"
            class="bg-gray-50 border border-gray-200 text-gray-500 text-xs rounded-xl px-4 py-2.5 outline-none focus:border-brand-green">
            <option value="all">كل الحالات</option>
            <option value="pending">قيد الانتظار</option>
            <option value="sent">تم الإرسال</option>
            <option value="failed">فشل الإرسال</option>
        </select>
    </div>

    <% if (contacts && contacts.length> 0) { %>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-50 bg-gray-50/50">
                        <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">الاسم</th>
                        <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">رقم الهاتف</th>
                        <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">الحملة</th>
                        <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">الحالة</th>
                        <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">تاريخ الإرسال</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50" id="contacts-tbody">
                    <% contacts.forEach(function(c) { %>
                        <tr class="hover:bg-gray-50/50 transition contact-row" data-name="<%= c.name.toLowerCase() %>"
                            data-phone="<%= c.phone %>" data-status="<%= c.status %>">
                            <td class="px-5 py-4 font-medium text-gray-800">
                                <%= c.name || '—' %>
                            </td>
                            <td class="px-5 py-4 text-gray-500 dir-ltr text-right">
                                <%= c.phone %>
                            </td>
                            <td class="px-5 py-4 text-gray-400 text-xs">
                                <%= c.campaign_name || '—' %>
                            </td>
                            <td class="px-5 py-4">
                                <% const st={ pending: 'bg-gray-100 text-gray-600' , sent: 'bg-green-100 text-green-700'
                                    , failed: 'bg-red-100 text-red-700' }; %>
                                    <% const labels={ pending: 'قيد الانتظار' , sent: 'تم الإرسال' , failed: 'فشل' }; %>
                                        <span
                                            class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold <%= st[c.status] || st.pending %>">
                                            <%= labels[c.status] || c.status %>
                                        </span>
                            </td>
                            <td class="px-5 py-4 text-gray-400 text-xs">
                                <%= c.sent_at ? new Date(c.sent_at).toLocaleString('ar-SA') : '—' %>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
        <% } else { %>
            <!-- Premium Empty State -->
            <div class="py-16 text-center relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-b from-brand-light/20 to-transparent"></div>
                <div class="relative z-10">
                    <div class="w-20 h-20 mx-auto mb-5 text-gray-300">
                        <svg fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-bold text-gray-700 mb-2">لا توجد جهات اتصال</h3>
                    <p class="text-gray-400 text-sm max-w-sm mx-auto">سيتم عرض جهات الاتصال هنا بمجرد رفع ملفات الأسماء في حملاتك.</p>
                </div>
            </div>
            <% } %>
</div>

<script>
    // Logic for filter & search
    const searchInput = document.getElementById('contact-search');
    const statusFilter = document.getElementById('status-filter');
    const rows = document.querySelectorAll('.contact-row');

    function filterContacts() {
        const query = searchInput.value.toLowerCase();
        const status = statusFilter.value;

        rows.forEach(row => {
            const nameMatch = row.dataset.name.includes(query) || row.dataset.phone.includes(query);
            const statusMatch = status === 'all' || row.dataset.status === status;
            row.style.display = (nameMatch && statusMatch) ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', filterContacts);
    statusFilter.addEventListener('change', filterContacts);
</script>