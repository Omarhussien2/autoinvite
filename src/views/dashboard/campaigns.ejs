<div>

    <%
        var safeColor = quota.safetyLevel === 'safe'    ? '#00C853' :
                        quota.safetyLevel === 'warning'  ? '#F59E0B' : '#EF4444';
    %>

    <!-- AntiBan Daily Bar (Qualitative Health Meter) -->
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-6 shadow-sm">
        <div class="flex items-center justify-between text-xs mb-3">
            <div class="flex items-center gap-2">
                <span class="p-1 px-2 rounded-lg bg-brand-light text-brand-dark font-bold">مؤشر صحة الوصول اليومي</span>
            </div>
            <% 
                var healthStatus = quota.safetyLevel === 'safe' ? 'ممتاز — حسابك في أعلى درجات الأمان' : 
                                   quota.safetyLevel === 'warning' ? 'جيد — ننصح بجدولة الرسائل المتبقية لتفادي الحظر' : 
                                   'مكثف — يفضل التوقف حالياً لضمان استقرار حسابك';
            %>
            <span class="font-bold uppercase tracking-wider" style="color:<%= safeColor %>">
                <%= healthStatus %>
            </span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden shadow-inner">
            <div class="h-3 rounded-full transition-all duration-1000 ease-out"
                 style="width:<%= quota.dailyPct %>%; background:<%= safeColor %>; box-shadow: 0 0 10px <%= safeColor %>44;">
            </div>
        </div>
        <div class="flex items-center justify-between text-[10px] text-gray-400 mt-2 font-medium">
            <span>بداية اليوم</span>
            <div class="flex items-center gap-1.5 bg-gray-50 px-2 py-0.5 rounded-full border border-gray-100">
                <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:<%= safeColor %>"></span>
                <span class="text-gray-500">معدل نشاط الحساب مستقر</span>
            </div>
            <span>الحد اليومي الآمن</span>
        </div>
    </div>

    <!-- Search + Table Card -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm">

        <!-- Search Bar -->
        <div class="px-5 py-4 border-b border-gray-50">
            <div class="relative max-w-xs">
                <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none"
                    stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="campaign-search" placeholder="البحث في الحملات"
                    class="w-full pr-10 pl-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 bg-gray-50">
            </div>
        </div>

        <% if (campaigns && campaigns.length > 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-50 bg-gray-50/50">
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">اسم الحملة</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">القالب</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs hidden md:table-cell">
                                نسبة التسليم</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs hidden lg:table-cell">
                                التاريخ</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">الحالة</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50" id="campaigns-tbody">
                        <% campaigns.forEach(function(c) { %>
                            <% const statusColors={ active: 'bg-green-50 text-green-700 border-green-100' ,
                                running: 'bg-green-500/10 text-green-600 border-green-200' ,
                                completed: 'bg-blue-50 text-blue-700 border-blue-100' ,
                                paused: 'bg-amber-50 text-amber-700 border-amber-100' ,
                                failed: 'bg-red-50 text-red-700 border-red-100' }; %>
                                <% const statusLabels={ active: 'نشطة' , running: 'جارية' , completed: 'مكتملة' ,
                                    paused: 'متوقفة' , failed: 'فشلت' }; %>
                                    <tr class="hover:bg-gray-50/50 transition campaign-row"
                                        data-name="<%= c.name.toLowerCase() %>"
                                        data-status="<%= c.status %>">
                                        <td class="px-5 py-4">
                                            <div class="flex items-center gap-3">
                                                <div
                                                    class="w-8 h-8 rounded-lg bg-brand-light flex-shrink-0 flex items-center justify-center">
                                                    <svg class="w-4 h-4 text-brand-dark" fill="none"
                                                        stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                                                    </svg>
                                                </div>
                                                <span class="font-medium text-gray-800 text-sm">
                                                    <%= c.name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-gray-500 text-xs">
                                            <%= c.template_path ? c.template_path.split('/').pop().substring(0,20)
                                                + '...' : '—' %>
                                        </td>
                                        <td class="px-5 py-4 hidden md:table-cell">
                                            <% const sent=c.last_sent_row || 0; %>
                                                <div class="flex items-center gap-2">
                                                    <div class="flex-1 bg-gray-100 rounded-full h-1.5 w-20">
                                                        <div class="bg-brand-green h-1.5 rounded-full"
                                                            style="width: <%= Math.min(sent, 100) %>%"></div>
                                                    </div>
                                                    <span class="text-xs text-gray-500">
                                                        <%= sent %>%
                                                    </span>
                                                </div>
                                        </td>
                                        <td class="px-5 py-4 text-gray-400 text-xs hidden lg:table-cell">
                                            <%= new Date(c.created_at).toLocaleDateString('ar-SA') %>
                                        </td>
                                        <td class="px-5 py-4">
                                            <span
                                                class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border <%= statusColors[c.status] || 'bg-gray-100 text-gray-600 border-gray-200' %>">
                                                <% if (c.status === 'running') { %>
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                                                <% } else if (c.status === 'completed') { %>
                                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                                <% } %>
                                                <%= statusLabels[c.status] || 'مسودة' %>
                                            </span>
                                        </td>
                                        <td class="px-5 py-4">
                                            <div class="flex items-center gap-1.5">
                                                <% if (c.status !== 'running' && c.status !== 'completed') { %>
                                                    <a href="/campaigns/<%= c.id %>/run" title="تشغيل"
                                                        class="w-9 h-9 rounded-lg bg-brand-light text-brand-dark flex items-center justify-center transition hover:bg-brand-green hover:text-white shadow-sm">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                        </svg>
                                                    </a>
                                                <% } else { %>
                                                    <span class="w-9 h-9 rounded-lg flex items-center justify-center text-gray-300 cursor-not-allowed bg-gray-50 border border-gray-100" title="الحملة <%= statusLabels[c.status] %>">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                            <path d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                        </svg>
                                                    </span>
                                                <% } %>

                                                <a href="/campaigns/<%= c.id %>/edit" title="تعديل"
                                                    class="w-9 h-9 rounded-lg hover:bg-gray-100 flex items-center justify-center transition text-gray-400 hover:text-gray-700 border border-gray-100">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                    </svg>
                                                </a>

                                                <button onclick="deleteCampaign('<%= c.id %>')" title="حذف"
                                                    class="w-9 h-9 rounded-lg hover:bg-red-50 flex items-center justify-center transition text-gray-400 hover:text-red-500 border border-gray-100">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                    </tbody>
                </table>
            </div>

            <% } else { %>
                <!-- Premium Empty State -->
                <div class="py-16 text-center relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-brand-light/30 to-transparent"></div>
                    <div class="relative z-10">
                        <div class="w-24 h-24 mx-auto mb-6 relative">
                            <svg class="w-24 h-24 text-brand-green/20" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                            </svg>
                            <div class="absolute -top-1 -right-1 w-6 h-6 bg-brand-green rounded-full flex items-center justify-center animate-pulse">
                                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                </svg>
                            </div>
                        </div>
                        <h3 class="text-lg font-bold text-gray-800 mb-2">لم تبدأ أي حملة بعد</h3>
                        <p class="text-gray-500 text-sm mb-6 max-w-sm mx-auto leading-relaxed">أطلق حملتك الأولى الآن لتصل إلى عملائك بذكاء عبر الواتساب.</p>
                        <a href="/campaigns/new"
                            class="inline-flex items-center gap-2 bg-brand-green text-white px-8 py-3.5 rounded-xl text-sm font-bold hover:bg-brand-dark transition-all duration-300 shadow-lg shadow-brand-green/20 hover:shadow-brand-green/30 animate-pulse">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                            </svg>
                            إنشاء حملة جديدة
                        </a>
                    </div>
                </div>
                <% } %>
    </div>

</div>

<script>
    document.getElementById('campaign-search').addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        document.querySelectorAll('.campaign-row').forEach(row => {
            row.style.display = row.dataset.name.includes(q) ? '' : 'none';
        });
    });

    async function deleteCampaign(id) {
        if (!confirm('هل أنت متأكد من حذف هذه الحملة؟')) return;
        try {
            const res = await fetch('/api/campaigns/' + id, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                showToast('success', 'تم حذف الحملة بنجاح');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast('error', 'فشل الحذف: ' + data.message);
            }
        } catch (e) {
            showToast('error', 'حدث خطأ أثناء الحذف');
        }
    }
</script>
