<div>

    <%
        var safeColor = quota.safetyLevel === 'safe'    ? '#00C853' :
                        quota.safetyLevel === 'warning'  ? '#F59E0B' : '#EF4444';
    %>

    <!-- AntiBan Daily Bar -->
    <div class="bg-white rounded-2xl border border-gray-100 p-4 mb-5 shadow-sm">
        <div class="flex items-center justify-between text-xs text-gray-500 mb-2">
            <span class="font-medium text-gray-700">🛡️ مقياس الأمان اليومي</span>
            <span style="color:<%= safeColor %>">
                الحد الموصى به: <%= quota.dailySafe %> رسالة/يوم
            </span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
            <div class="h-2.5 rounded-full transition-all duration-700"
                 style="width:<%= quota.dailyPct %>%; background:<%= safeColor %>;">
            </div>
        </div>
        <div class="flex items-center justify-between text-xs mt-1.5">
            <span class="text-gray-400">0</span>
            <span class="font-medium" style="color:<%= safeColor %>">
                <%= quota.dailyCount %> / <%= quota.dailySafe %> رسالة اليوم
            </span>
            <span class="text-gray-400"><%= quota.dailySafe %></span>
        </div>
    </div>

    <!-- Search + Table Card -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm">

        <!-- Search Bar -->
        <div class="px-5 py-4 border-b border-gray-50">
            <div class="relative max-w-xs">
                <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none"
                    stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="campaign-search" placeholder="البحث في الحملات"
                    class="w-full pr-10 pl-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 bg-gray-50">
            </div>
        </div>

        <% if (campaigns && campaigns.length> 0) { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-50 bg-gray-50/50">
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">اسم الحملة</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">القالب</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs hidden md:table-cell">
                                نسبة التسليم</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs hidden lg:table-cell">
                                التاريخ</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">الحالة</th>
                            <th class="text-right px-5 py-3.5 font-medium text-gray-500 text-xs">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50" id="campaigns-tbody">
                        <% campaigns.forEach(function(c) { %>
                            <% const statusColors={ active: 'bg-green-50 text-green-700 border-green-100' ,
                                running: 'bg-blue-50 text-blue-700 border-blue-100' ,
                                completed: 'bg-gray-100 text-gray-600 border-gray-200' ,
                                paused: 'bg-amber-50 text-amber-700 border-amber-100' ,
                                failed: 'bg-red-50 text-red-700 border-red-100' }; %>
                                <% const statusLabels={ active: 'نشطة' , running: 'جارية' , completed: 'مكتملة' ,
                                    paused: 'متوقفة' , failed: 'فشلت' }; %>
                                    <tr class="hover:bg-gray-50/50 transition campaign-row"
                                        data-name="<%= c.name.toLowerCase() %>">
                                        <td class="px-5 py-4">
                                            <div class="flex items-center gap-3">
                                                <div
                                                    class="w-8 h-8 rounded-lg bg-brand-light flex-shrink-0 flex items-center justify-center">
                                                    <svg class="w-4 h-4 text-brand-dark" fill="none"
                                                        stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                                                    </svg>
                                                </div>
                                                <span class="font-medium text-gray-800 text-sm">
                                                    <%= c.name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-gray-500 text-xs">
                                            <%= c.template_path ? c.template_path.split('/').pop().substring(0,20)
                                                + '...' : '—' %>
                                        </td>
                                        <td class="px-5 py-4 hidden md:table-cell">
                                            <% const sent=c.last_sent_row || 0; %>
                                                <div class="flex items-center gap-2">
                                                    <div class="flex-1 bg-gray-100 rounded-full h-1.5 w-20">
                                                        <div class="bg-brand-green h-1.5 rounded-full"
                                                            style="width: <%= Math.min(sent, 100) %>%"></div>
                                                    </div>
                                                    <span class="text-xs text-gray-500">
                                                        <%= sent %>%
                                                    </span>
                                                </div>
                                        </td>
                                        <td class="px-5 py-4 text-gray-400 text-xs hidden lg:table-cell">
                                            <%= new Date(c.created_at).toLocaleDateString('ar-SA') %>
                                        </td>
                                        <td class="px-5 py-4">
                                            <span
                                                class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium border <%= statusColors[c.status] || 'bg-gray-100 text-gray-600 border-gray-200' %>">
                                                <% if (c.status==='running' ) { %><span
                                                        class="w-1.5 h-1.5 rounded-full bg-blue-500 mr-1 animate-pulse"></span>
                                                    <% } %>
                                                        <%= statusLabels[c.status] || 'مسودة' %>
                                            </span>
                                        </td>
                                        <td class="px-5 py-4">
                                            <div class="flex items-center gap-1">
                                                <a href="/campaigns/<%= c.id %>/run" title="تشغيل"
                                                    class="w-7 h-7 rounded-lg hover:bg-brand-light flex items-center justify-center transition text-gray-400 hover:text-brand-dark">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                        stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                </a>
                                                <a href="/campaigns/<%= c.id %>/edit" title="تعديل"
                                                    class="w-7 h-7 rounded-lg hover:bg-gray-100 flex items-center justify-center transition text-gray-400 hover:text-gray-700">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                        stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                    </svg>
                                                </a>
                                                <button onclick="deleteCampaign('<%= c.id %>')" title="حذف"
                                                    class="w-7 h-7 rounded-lg hover:bg-red-50 flex items-center justify-center transition text-gray-400 hover:text-red-500">
                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                        stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                    </tbody>
                </table>
            </div>

            <% } else { %>
                <!-- Empty State -->
                <div class="py-20 text-center">
                    <div class="w-16 h-16 mx-auto mb-4 text-gray-200">
                        <svg fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                    </div>
                    <p class="text-gray-600 font-medium mb-1">لا توجد لديك حملات</p>
                    <p class="text-gray-400 text-sm mb-5">أنشئ حملتك الأولى لبدء إرسال الدعوات عبر الواتساب.</p>
                    <a href="/campaigns/new"
                        class="inline-flex items-center gap-2 bg-brand-dark text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:opacity-90 transition shadow-sm">إنشاء
                        حملة</a>
                </div>
                <% } %>
    </div>

</div>

<script>
    document.getElementById('campaign-search').addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        document.querySelectorAll('.campaign-row').forEach(row => {
            row.style.display = row.dataset.name.includes(q) ? '' : 'none';
        });
    });

    async function deleteCampaign(id) {
        if (!confirm('هل أنت متأكد من حذف هذه الحملة؟')) return;
        try {
            const res = await fetch('/api/campaigns/' + id, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) window.location.reload();
            else alert('فشل الحذف: ' + data.message);
        } catch (e) { alert('حدث خطأ.'); }
    }
</script>