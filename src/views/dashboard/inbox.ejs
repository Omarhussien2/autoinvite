<!-- Live Inbox: Two-Pane Layout -->
<div class="flex h-[calc(100vh-140px)] bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <!-- ===== RIGHT PANE: Contact List ===== -->
    <div id="contact-list-pane" class="w-80 max-md:w-full flex-shrink-0 border-l border-gray-100 flex flex-col bg-white">

        <!-- Search -->
        <div class="p-4 border-b border-gray-50">
            <div class="relative">
                <svg class="w-4 h-4 absolute right-3 top-1/2 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input id="contact-search" type="text" placeholder="ابحث في المحادثات..."
                    class="w-full pr-10 pl-4 py-2.5 bg-gray-50 border border-gray-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green transition">
            </div>
        </div>

        <!-- Conversations -->
        <div id="conversations-list" class="flex-1 overflow-y-auto custom-scrollbar">
            <% if (conversations.length === 0) { %>
                <div id="empty-conversations" class="flex flex-col items-center justify-center h-full text-gray-400 px-6 text-center">
                    <svg class="w-12 h-12 mb-3 text-gray-200" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                    </svg>
                    <p class="text-sm font-medium">لا توجد محادثات بعد</p>
                    <p class="text-xs mt-1">الرسائل الواردة ستظهر هنا تلقائياً</p>
                </div>
            <% } else { %>
                <% conversations.forEach(function(conv) {
                    const unread = (typeof unreadMap !== 'undefined' && unreadMap[conv.remote_phone]) || 0;
                    const displayName = conv.sender_name || conv.remote_phone;
                %>
                    <div class="conversation-item cursor-pointer px-4 py-3.5 border-b border-gray-50 hover:bg-gray-50/80 transition-all duration-150"
                         data-phone="<%= conv.remote_phone %>"
                         data-name="<%= displayName %>"
                         onclick="openConversation('<%= conv.remote_phone %>', '<%= displayName.replace(/'/g, "\\'") %>')">
                        <div class="flex items-center gap-3">
                            <!-- Avatar -->
                            <div class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center flex-shrink-0">
                                <span class="text-brand-dark font-bold text-sm"><%= displayName.substring(0, 2) %></span>
                            </div>
                            <!-- Info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-bold text-gray-900 truncate"><%= displayName %></span>
                                    <span class="text-[10px] text-gray-400 flex-shrink-0"><%= conv.created_at ? new Date(conv.created_at).toLocaleDateString('ar-SA', { month: 'short', day: 'numeric' }) : '' %></span>
                                </div>
                                <p class="text-xs text-gray-500 truncate mt-0.5">
                                    <% if (conv.direction === 'outbound') { %><span class="text-brand-green">أنت:</span> <% } %>
                                    <%= (conv.body || '').substring(0, 50) %>
                                </p>
                            </div>
                            <!-- Unread badge -->
                            <% if (unread > 0) { %>
                            <div class="unread-dot w-5 h-5 bg-brand-green rounded-full flex items-center justify-center flex-shrink-0 status-pulse">
                                <span class="text-[9px] font-bold text-white"><%= unread > 9 ? '9+' : unread %></span>
                            </div>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <!-- ===== LEFT PANE: Chat Window ===== -->
    <div id="chat-pane" class="flex-1 flex flex-col bg-surface-gray max-md:hidden">

        <!-- Empty state -->
        <div id="chat-empty" class="flex-1 flex flex-col items-center justify-center text-gray-400">
            <svg class="w-20 h-20 mb-4 text-gray-200" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <p class="text-sm font-medium">اختر محادثة للبدء</p>
            <p class="text-xs mt-1">اضغط على أي جهة اتصال من القائمة</p>
        </div>

        <!-- Active chat -->
        <div id="chat-active" class="flex-1 flex flex-col hidden">

            <!-- Chat header -->
            <div id="chat-header" class="px-6 py-4 bg-white border-b border-gray-100 flex items-center gap-3">
                <!-- Back button (mobile) -->
                <button id="chat-back-btn" class="md:hidden ml-2" onclick="closeChat()">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
                <div class="w-10 h-10 rounded-full bg-brand-dark flex items-center justify-center flex-shrink-0">
                    <span id="chat-avatar" class="text-white font-bold text-sm"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <p id="chat-name" class="text-sm font-bold text-gray-900 truncate"></p>
                    <p id="chat-phone-sub" class="text-[10px] text-gray-400 font-mono"></p>
                </div>
                <div id="chat-online-dot" class="w-2.5 h-2.5 bg-brand-green rounded-full status-pulse"></div>
            </div>

            <!-- Messages area -->
            <div id="chat-messages" class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-2">
            </div>

            <!-- Reply input -->
            <div class="p-4 bg-white border-t border-gray-100">
                <form id="reply-form" class="flex items-end gap-3" onsubmit="sendReply(event)">
                    <textarea id="reply-input" placeholder="اكتب ردك هنا..."
                        rows="1"
                        autocomplete="off"
                        class="flex-1 px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-green/30 focus:border-brand-green transition resize-none max-h-32 overflow-y-auto leading-relaxed"
                        onkeydown="handleReplyKey(event)"
                        oninput="autoResize(this)"></textarea>
                    <button type="submit" id="reply-btn"
                        class="bg-brand-dark text-white px-5 py-3 rounded-xl text-sm font-medium hover:opacity-90 transition flex items-center gap-2 flex-shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
                        <span id="reply-btn-text">إرسال</span>
                        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Notification sound (subtle) -->
<audio id="notif-sound" preload="auto" src="data:audio/wav;base64,UklGRl9vT19teleUZXZZgAACAAIABAAIAAABAAEAAAAAAAAAAAAAAAAAAAAAA=="></audio>

<script>
// ── State ──────────────────────────────────────────────────────────
let activePhone = null;
let activeName = null;
let typingTimeout = null;
const socket = io();

// ── Open a conversation ────────────────────────────────────────────
async function openConversation(phone, name) {
    activePhone = phone;
    activeName = name || phone;

    // Highlight active contact
    document.querySelectorAll('.conversation-item').forEach(el => {
        const isActive = el.dataset.phone === phone;
        el.classList.toggle('bg-brand-light/50', isActive);
        el.classList.toggle('border-r-2', isActive);
        el.classList.toggle('border-brand-green', isActive);
    });

    // Remove unread dot from this conversation
    const activeItem = document.querySelector(`.conversation-item[data-phone="${phone}"]`);
    if (activeItem) {
        const dot = activeItem.querySelector('.unread-dot');
        if (dot) dot.remove();
    }

    // Mobile: show chat pane, hide list
    document.getElementById('chat-pane').classList.remove('max-md:hidden');
    document.getElementById('contact-list-pane').classList.add('max-md:hidden');

    // Show chat pane
    document.getElementById('chat-empty').classList.add('hidden');
    document.getElementById('chat-active').classList.remove('hidden');
    document.getElementById('chat-name').textContent = activeName;
    document.getElementById('chat-phone-sub').textContent = phone;
    document.getElementById('chat-avatar').textContent = activeName.substring(0, 2);
    document.getElementById('chat-messages').innerHTML = `
        <div class="flex justify-center py-8">
            <div class="w-6 h-6 border-2 border-brand-green border-t-transparent rounded-full animate-spin"></div>
        </div>
    `;

    // Fetch messages
    try {
        const res = await fetch('/api/inbox/' + encodeURIComponent(phone) + '/messages');
        const data = await res.json();
        if (data.success) {
            renderMessages(data.messages);
        }
    } catch (e) {
        document.getElementById('chat-messages').innerHTML = `
            <div class="flex justify-center py-8 text-red-400 text-sm">فشل تحميل الرسائل</div>
        `;
    }

    // Focus reply input
    document.getElementById('reply-input').focus();

    // Recalculate sidebar badge
    recalcBadge();
}

// ── Close chat (mobile back) ─────────────────────────────────────
function closeChat() {
    document.getElementById('chat-pane').classList.add('max-md:hidden');
    document.getElementById('contact-list-pane').classList.remove('max-md:hidden');
    activePhone = null;
}

// ── Render messages with date separators ──────────────────────────
function renderMessages(messages) {
    const container = document.getElementById('chat-messages');
    if (messages.length === 0) {
        container.innerHTML = `
            <div class="flex justify-center py-8 text-gray-400 text-sm">لا توجد رسائل بعد</div>
        `;
        return;
    }

    let html = '';
    let lastDate = '';

    messages.forEach(msg => {
        const msgDate = msg.whatsapp_timestamp
            ? new Date(msg.whatsapp_timestamp).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' })
            : '';

        // Date separator
        if (msgDate && msgDate !== lastDate) {
            html += `
                <div class="flex items-center gap-3 my-4">
                    <div class="flex-1 h-px bg-gray-200"></div>
                    <span class="text-[10px] text-gray-400 bg-surface-gray px-3 py-1 rounded-full font-medium">${msgDate}</span>
                    <div class="flex-1 h-px bg-gray-200"></div>
                </div>
            `;
            lastDate = msgDate;
        }

        html += messageBubble(msg);
    });

    container.innerHTML = html;
    // Scroll to bottom smoothly
    requestAnimationFrame(() => { container.scrollTop = container.scrollHeight; });
}

function messageBubble(msg) {
    const isMe = msg.direction === 'outbound';
    const time = msg.whatsapp_timestamp
        ? new Date(msg.whatsapp_timestamp).toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit' })
        : '';

    if (isMe) {
        return `
            <div class="flex justify-start animate-[fadeIn_0.2s_ease]">
                <div class="max-w-[75%] bg-brand-dark text-white px-4 py-2.5 rounded-2xl rounded-bl-sm shadow-sm">
                    <p class="text-sm leading-relaxed whitespace-pre-wrap">${escapeHtml(msg.body || '')}</p>
                    <div class="flex items-center gap-1 mt-1">
                        <p class="text-[10px] text-white/50">${time}</p>
                        <svg class="w-3 h-3 text-white/40" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    </div>
                </div>
            </div>
        `;
    } else {
        return `
            <div class="flex justify-end animate-[fadeIn_0.2s_ease]">
                <div class="max-w-[75%] bg-white px-4 py-2.5 rounded-2xl rounded-br-sm shadow-sm border border-gray-100">
                    <p class="text-sm text-gray-800 leading-relaxed whitespace-pre-wrap">${escapeHtml(msg.body || '')}</p>
                    <p class="text-[10px] text-gray-400 mt-1">${time}</p>
                </div>
            </div>
        `;
    }
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// ── Textarea auto-resize & Enter key ──────────────────────────────
function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 128) + 'px';
}

function handleReplyKey(e) {
    // Enter = send, Shift+Enter = newline
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('reply-form').dispatchEvent(new Event('submit', { cancelable: true }));
    }
}

// ── Send reply ─────────────────────────────────────────────────────
async function sendReply(e) {
    e.preventDefault();
    const input = document.getElementById('reply-input');
    const body = input.value.trim();
    if (!body || !activePhone) return;

    const btn = document.getElementById('reply-btn');
    const btnText = document.getElementById('reply-btn-text');
    btn.disabled = true;
    btnText.textContent = 'جاري الإرسال...';
    input.value = '';
    autoResize(input);

    try {
        const res = await fetch('/api/inbox/' + encodeURIComponent(activePhone) + '/reply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ body }),
        });
        const data = await res.json();
        if (data.success) {
            appendMessage({
                direction: 'outbound',
                body,
                whatsapp_timestamp: new Date().toISOString(),
            });
            // Update conversation list snippet
            updateConversationSnippet(activePhone, 'أنت: ' + body.substring(0, 40));
        } else {
            showToast('error', data.message || 'فشل إرسال الرد');
            input.value = body; // Restore message
        }
    } catch (err) {
        showToast('error', 'خطأ في الاتصال بالسيرفر');
        input.value = body;
    } finally {
        btn.disabled = false;
        btnText.textContent = 'إرسال';
        input.focus();
    }
}

// ── Append a single message ────────────────────────────────────────
function appendMessage(msg) {
    const container = document.getElementById('chat-messages');
    // Remove placeholder if present
    const placeholder = container.querySelector('.text-gray-400');
    if (placeholder && placeholder.closest('.flex.justify-center')) {
        placeholder.closest('.flex.justify-center').remove();
    }
    container.insertAdjacentHTML('beforeend', messageBubble(msg));
    requestAnimationFrame(() => { container.scrollTop = container.scrollHeight; });
}

// ── Socket.io: Real-time incoming messages ─────────────────────────
socket.on('new_whatsapp_message', (data) => {
    // Play notification sound
    playNotifSound();

    // Update conversation list
    updateConversationList(data);

    // If this conversation is active, append the message
    if (data.from === activePhone) {
        appendMessage({
            direction: 'inbound',
            body: data.body,
            whatsapp_timestamp: data.timestamp ? new Date(data.timestamp * 1000).toISOString() : new Date().toISOString(),
        });
    } else {
        // Increment sidebar badge for unread
        incrementBadge();
    }
});

function playNotifSound() {
    try {
        // Create a simple beep with AudioContext (reliable, no external file)
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = 800;
        osc.type = 'sine';
        gain.gain.value = 0.1;
        osc.start();
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
        osc.stop(ctx.currentTime + 0.3);
    } catch (_) {}
}

function updateConversationList(data) {
    const list = document.getElementById('conversations-list');
    const existingItem = list.querySelector(`[data-phone="${CSS.escape(data.from)}"]`);

    // Remove empty state
    const emptyState = document.getElementById('empty-conversations');
    if (emptyState) emptyState.remove();

    const displayName = data.name || data.from;
    const snippet = escapeHtml(data.body ? data.body.substring(0, 50) : '');
    const now = new Date().toLocaleDateString('ar-SA', { month: 'short', day: 'numeric' });
    const isActive = data.from === activePhone;

    const innerHtml = `
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center flex-shrink-0">
                <span class="text-brand-dark font-bold text-sm">${escapeHtml(displayName.substring(0, 2))}</span>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-gray-900 truncate">${escapeHtml(displayName)}</span>
                    <span class="text-[10px] text-gray-400 flex-shrink-0">${now}</span>
                </div>
                <p class="text-xs text-gray-500 truncate mt-0.5">${snippet}</p>
            </div>
            ${!isActive ? '<div class="unread-dot w-2.5 h-2.5 bg-brand-green rounded-full flex-shrink-0 status-pulse"></div>' : ''}
        </div>
    `;

    if (existingItem) {
        existingItem.innerHTML = innerHtml;
        existingItem.dataset.name = displayName;
        list.prepend(existingItem);
    } else {
        const div = document.createElement('div');
        div.className = 'conversation-item cursor-pointer px-4 py-3.5 border-b border-gray-50 hover:bg-gray-50/80 transition-all duration-150';
        div.dataset.phone = data.from;
        div.dataset.name = displayName;
        div.setAttribute('onclick', `openConversation('${data.from.replace(/'/g, "\\'")}', '${displayName.replace(/'/g, "\\'")}')`);
        div.innerHTML = innerHtml;
        list.prepend(div);
    }
}

function updateConversationSnippet(phone, text) {
    const item = document.querySelector(`.conversation-item[data-phone="${CSS.escape(phone)}"]`);
    if (!item) return;
    const snippetEl = item.querySelector('.text-xs.text-gray-500');
    if (snippetEl) snippetEl.textContent = text;
}

// ── Sidebar badge ──────────────────────────────────────────────────
function incrementBadge() {
    const badge = document.getElementById('inbox-badge');
    if (!badge) return;
    const current = parseInt(badge.textContent || '0');
    badge.textContent = current + 1;
    badge.classList.remove('hidden');
}

function recalcBadge() {
    // Count remaining unread dots in conversation list
    const dots = document.querySelectorAll('.unread-dot').length;
    const badge = document.getElementById('inbox-badge');
    if (!badge) return;
    if (dots > 0) {
        badge.textContent = dots;
        badge.classList.remove('hidden');
    } else {
        badge.classList.add('hidden');
    }
}

// ── Contact search filter ──────────────────────────────────────────
document.getElementById('contact-search').addEventListener('input', function() {
    const query = this.value.toLowerCase();
    document.querySelectorAll('.conversation-item').forEach(el => {
        const phone = (el.dataset.phone || '').toLowerCase();
        const name = (el.dataset.name || '').toLowerCase();
        const text = el.textContent.toLowerCase();
        el.style.display = (phone.includes(query) || name.includes(query) || text.includes(query)) ? '' : 'none';
    });
});

// ── Initialize sidebar badge from server data ──────────────────────
(function initBadge() {
    <% if (typeof unreadMap !== 'undefined') { %>
    const totalUnread = <%= Object.values(unreadMap).reduce((a, b) => a + b, 0) %>;
    if (totalUnread > 0) {
        const badge = document.getElementById('inbox-badge');
        if (badge) {
            badge.textContent = totalUnread > 99 ? '99+' : totalUnread;
            badge.classList.remove('hidden');
        }
    }
    <% } %>
})();
</script>
