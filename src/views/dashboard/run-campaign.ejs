<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 max-w-6xl mx-auto">

    <!-- Right: Status & Logs (8 cols) -->
    <div class="lg:col-span-8 space-y-6">

        <!-- Real-time Logs -->
        <div class="bg-gray-950 rounded-2xl border border-gray-800 p-6 shadow-2xl">
            <div class="flex items-center justify-between mb-4 border-b border-gray-900 pb-3">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-green animate-pulse"></span>
                    سجل العمليات المباشر
                </h3>
                <div class="flex items-center gap-2">
                    <span id="log-count"
                        class="text-[10px] text-gray-500 bg-gray-900 px-2 py-0.5 rounded border border-gray-800">0
                        سجل</span>
                    <button id="clear-logs" class="text-[10px] text-gray-500 hover:text-white transition">مسح</button>
                </div>
            </div>

            <div id="logs-area" class="h-96 overflow-y-auto pr-1">
                <p class="text-gray-600 italic text-xs">في انتظار بدء الحملة...</p>
            </div>
        </div>

        <!-- Stats summary during run -->
        <div class="grid grid-cols-3 gap-4">
            <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
                <p id="total-sent" class="text-2xl font-bold text-gray-900">0</p>
                <p class="text-[10px] text-gray-400">تم الإرسال</p>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
                <p id="success-count" class="text-2xl font-bold text-brand-green">0</p>
                <p class="text-[10px] text-gray-400">نجاح ✅</p>
            </div>
            <div class="bg-white rounded-2xl border border-gray-100 p-4 text-center">
                <p id="fail-count" class="text-2xl font-bold text-red-500">0</p>
                <p class="text-[10px] text-gray-400">فشل ❌</p>
            </div>
        </div>
    </div>

    <!-- Left: Controls & Context (4 cols) -->
    <div class="lg:col-span-4 space-y-6">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm sticky top-24">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-brand-light rounded-2xl flex items-center justify-center mx-auto mb-3">
                    <svg class="w-8 h-8 text-brand-dark" fill="none" stroke="currentColor" stroke-width="2"
                        viewBox="0 0 24 24">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <h3 class="font-bold text-gray-900">
                    <%= campaign.name %>
                </h3>
                <p class="text-xs text-gray-400 mt-1">الحالة: <span id="run-status"
                        class="bg-gray-100 px-2 py-0.5 rounded text-xs">متوقفة</span></p>
            </div>

            <% if (contactsCount > 0) { %>
            <div class="bg-brand-light rounded-xl px-4 py-2.5 flex items-center justify-between text-xs mb-1">
                <span class="text-brand-dark font-medium">إجمالي جهات الاتصال</span>
                <span class="font-bold text-brand-green text-sm"><%= contactsCount %> جهة</span>
            </div>
            <% } %>
            <% if (contactsCount === 0) { %>
            <div class="bg-red-50 rounded-xl px-4 py-2.5 text-xs text-red-600 text-center mb-1">
                ⚠️ لم يتم رفع ملف الأرقام بعد
            </div>
            <% } %>

            <div class="space-y-4">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="text-[10px] text-gray-500">من صف #</label>
                        <input type="number" id="startRow" value="<%= campaign.last_sent_row || 1 %>"
                            class="w-full text-sm border border-gray-200 rounded-lg p-2 focus:border-brand-green outline-none">
                    </div>
                    <div>
                        <label class="text-[10px] text-gray-500">إلى صف # <% if(contactsCount>0){%>(max <%= contactsCount %>)<%}%></label>
                        <input type="number" id="endRow" value="<%= contactsCount || 100 %>"
                            class="w-full text-sm border border-gray-200 rounded-lg p-2 focus:border-brand-green outline-none">
                    </div>
                </div>

                <button id="start-btn"
                    class="w-full bg-brand-dark text-white py-3 rounded-xl font-bold shadow-lg hover:opacity-95 transition flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                    </svg>
                    أطلق الحملة الآن
                </button>

                <button id="stop-btn"
                    class="hidden w-full bg-red-50 text-red-600 border border-red-100 py-3 rounded-xl font-bold hover:bg-red-100 transition flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                    </svg>
                    إيقاف مؤقت
                </button>
            </div>

            <!-- Quick Test -->
            <div class="mt-8 pt-6 border-t border-gray-100">
                <p class="text-xs font-semibold text-gray-800 mb-3 text-center">🧪 تجربة سريعة</p>
                <div class="flex gap-2">
                    <input type="text" id="testPhone" placeholder="الرقم (مثلاً 2011xxxxx)"
                        class="flex-1 text-xs border border-gray-200 rounded-lg p-2 outline-none">
                    <button id="test-btn"
                        class="bg-gray-100 text-gray-600 px-3 py-2 rounded-lg text-xs hover:bg-gray-200 transition">تجربة</button>
                </div>
            </div>
        </div>
    </div>

</div>

<script src="/js/campaign-runner.js"></script>
<script>
    var socket = io();
    initRunner(socket, '<%= campaign.id %>', '<%= campaign.tenant_id %>');
</script>