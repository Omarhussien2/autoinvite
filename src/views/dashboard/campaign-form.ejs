<style>
@keyframes vr-pulse {
    0%   { transform: scale(1);   opacity: 0.5; }
    100% { transform: scale(1.9); opacity: 0; }
}
#pulse-ring-1 { animation: vr-pulse 1.8s ease-out infinite; }
#pulse-ring-2 { animation: vr-pulse 1.8s ease-out 0.6s infinite; }
#vr-idle:not(.animate-pulse-off) #pulse-ring-1,
#vr-idle:not(.animate-pulse-off) #pulse-ring-2 { opacity: 1; }
</style>
<div class="max-w-6xl mx-auto">
    <form id="campaign-form" class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- Right Col: Settings (7 cols) -->
        <div class="lg:col-span-7 space-y-6">

            <!-- Basic Info -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h3 class="text-sm font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <span
                        class="w-6 h-6 bg-brand-light rounded flex items-center justify-center text-brand-dark">1</span>
                    تفاصيل الحملة الأساسية
                </h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 mb-1.5">اسم المناسبة / الحملة</label>
                        <input type="text" id="campName" required value="<%= campaign ? campaign.name : '' %>"
                            placeholder="مثلاً: دعوة زواج فهد 1447"
                            class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 transition">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1.5">صورة الدعوة (القالب) <span class="bg-yellow-100 text-yellow-800 text-[10px] font-medium px-2 py-0.5 rounded mr-1">قريباً 🚀</span></label>
                            <div class="relative group opacity-50 pointer-events-none">
                                <input type="file" id="imgUpload" accept="image/*" disabled
                                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                <div
                                    class="w-full px-4 py-2.5 rounded-xl border border-dashed border-gray-300 text-xs text-center text-gray-500 group-hover:border-brand-green transition">
                                    <%= campaign ? 'تغيير الصورة 🖼️' : 'اضغط لرفع الصورة 🖼️' %>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1.5">ملف الأرقام
                                (Excel/CSV)</label>
                            <div class="relative group">
                                <input type="file" id="contactsUpload" accept=".csv, .xlsx, .xls" <%=campaign ? ''
                                    : 'required' %> class="absolute inset-0 w-full h-full opacity-0 cursor-pointer
                                z-10">
                                <div id="contactsUploadLabel"
                                    class="w-full px-4 py-2.5 rounded-xl border border-dashed border-gray-300 text-xs text-center text-gray-500 group-hover:border-brand-green transition text-ellipsis overflow-hidden whitespace-nowrap">
                                    <%= campaign && campaign.contacts_path ? '📊 ' + campaign.contacts_path.split('/').pop() : (campaign ? 'تحديث ملف الأرقام 📊' : 'ارفع ملف الأسماء 📊') %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <p class="text-[10px] text-gray-400">
                        💡 تأكد إن ملف الأرقام يحتوي على عمود "Name" وعمود "Phone".
                        <a href="/assets/template.xlsx" download class="text-brand-green font-medium hover:underline mr-1">
                            📥 حمّل النموذج (Excel)
                        </a>
                    </p>
                </div>
            </div>

            <!-- Messages Variations -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h3 class="text-sm font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <span class="w-6 h-6 bg-brand-light rounded flex items-center justify-center text-brand-dark">2</span>
                    محتوى الرسالة
                </h3>

                <!-- Content Type Tabs -->
                <div class="flex gap-1 p-1 bg-gray-100 rounded-xl mb-5">
                    <button type="button" id="tab-text" onclick="switchTab('text')"
                        class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 bg-white text-brand-dark shadow-sm">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
                        رسالة نصية
                    </button>
                    <button type="button" id="tab-voice" onclick="switchTab('voice')"
                        class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 text-gray-500 hover:text-gray-700">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
                        رسالة صوتية
                    </button>
                </div>

                <!-- Text Tab Content -->
                <div id="content-text">
                    <p class="text-xs text-brand-green mb-4">💡 استخدم <code>[الاسم]</code> ليتم استبداله باسم الضيف تلقائياً.</p>
                    <div id="messages-list" class="space-y-4">
                    <% let msgs=[{ text: '' , weight: '3' }]; if (campaign && campaign.message_templates) { try {
                        msgs=JSON.parse(campaign.message_templates); } catch(e) {} } %>
                        <% msgs.forEach(function(m, i) { %>
                            <div
                                class="message-box relative group bg-gray-50/50 p-4 rounded-xl border border-gray-100 hover:border-brand-green transition">
                                <div class="flex items-center justify-between mb-2">
                                    <select
                                        class="msg-weight text-[10px] bg-white border border-gray-200 rounded px-2 py-1 outline-none">
                                        <option value="3" <%=m.weight=='3' ? 'selected' : '' %>>🌟 عالي (50%)</option>
                                        <option value="2" <%=m.weight=='2' ? 'selected' : '' %>>⚖️ متوسط (30%)</option>
                                        <option value="1" <%=m.weight=='1' ? 'selected' : '' %>>🔽 منخفض (20%)</option>
                                    </select>
                                    <button type="button"
                                        class="remove-msg text-gray-300 hover:text-red-500 transition">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                                <textarea name="message[]" rows="2" placeholder="حياك الله يا [الاسم]..."
                                    class="w-full bg-transparent border-none text-sm focus:ring-0 resize-none outline-none"><%= m.text %></textarea>
                            </div>
                            <% }) %>
                </div>

                    <button type="button" id="addMsgBtn"
                        class="w-full mt-4 py-2 border border-dashed border-gray-200 rounded-xl text-xs text-gray-400 hover:text-brand-green hover:border-brand-green transition">
                        + إضافة تنويع جديد
                    </button>
                </div><!-- end #content-text -->

                <!-- Voice Note Tab Content -->
                <div id="content-voice" class="hidden">

                    <!-- Recorder Stage -->
                    <div id="recorder-stage" class="relative rounded-2xl overflow-hidden mb-4" style="background: linear-gradient(135deg, #0A3D2E 0%, #1B5E20 100%); min-height: 220px;">

                        <!-- State: IDLE -->
                        <div id="vr-idle" class="flex flex-col items-center justify-center gap-4 py-10 px-6">
                            <p class="text-white/60 text-[11px] tracking-widest uppercase">اضغط للتسجيل</p>
                            <button type="button" id="btn-record"
                                class="relative w-20 h-20 rounded-full bg-white/10 border-2 border-white/20 flex items-center justify-center hover:bg-white/20 transition-all duration-300 group"
                                onclick="startRecording()">
                                <!-- Pulse rings -->
                                <span class="absolute inset-0 rounded-full border-2 border-white/20" id="pulse-ring-1"></span>
                                <span class="absolute inset-0 rounded-full border-2 border-white/10" id="pulse-ring-2"></span>
                                <svg class="w-8 h-8 text-white group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
                                </svg>
                            </button>
                            <p class="text-white/40 text-[10px]">أو <button type="button" onclick="document.getElementById('voicenoteUpload').click()" class="text-white/60 underline underline-offset-2 hover:text-white transition">ارفع ملفاً</button></p>
                            <!-- Hidden file input -->
                            <input type="file" id="voicenoteUpload" accept=".mp3,.ogg,.m4a,.wav,.webm" class="hidden">
                            <% if (campaign && campaign.voicenote_path) { %>
                            <p class="text-brand-green/80 text-[10px] font-medium mt-1">محفوظ: <%= campaign.voicenote_path.split('/').pop() %></p>
                            <% } %>
                        </div>

                        <!-- State: RECORDING -->
                        <div id="vr-recording" class="hidden flex-col items-center justify-center gap-4 py-8 px-6">
                            <!-- Timer -->
                            <div id="rec-timer" class="text-white font-mono text-3xl font-bold tracking-widest tabular-nums">00:00</div>
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 bg-red-400 rounded-full animate-pulse"></span>
                                <span class="text-white/60 text-[11px] tracking-widest uppercase">يسجّل الآن</span>
                            </div>
                            <!-- Live waveform canvas -->
                            <canvas id="waveform-canvas" width="280" height="48" class="w-full max-w-xs opacity-80"></canvas>
                            <!-- Stop button -->
                            <button type="button" id="btn-stop"
                                class="mt-2 w-14 h-14 rounded-full bg-red-500/90 hover:bg-red-500 border-2 border-red-400/50 flex items-center justify-center transition-all duration-200 shadow-lg shadow-red-500/30"
                                onclick="stopRecording()">
                                <span class="w-5 h-5 bg-white rounded-sm"></span>
                            </button>
                            <p class="text-white/40 text-[10px]">اضغط للإيقاف</p>
                        </div>

                        <!-- State: RECORDED -->
                        <div id="vr-recorded" class="hidden flex-col items-center justify-center gap-4 py-8 px-6">
                            <!-- Success check -->
                            <div class="w-14 h-14 rounded-full bg-brand-green/20 border-2 border-brand-green/40 flex items-center justify-center">
                                <svg class="w-7 h-7 text-brand-green" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                            <div class="text-center">
                                <p class="text-white font-semibold text-sm">تم التسجيل</p>
                                <p id="rec-final-duration" class="text-white/50 text-[11px] mt-0.5"></p>
                            </div>
                            <!-- Playback bar -->
                            <div class="w-full max-w-xs">
                                <div class="flex items-center gap-3">
                                    <button type="button" id="btn-play" onclick="togglePlayback()"
                                        class="w-9 h-9 rounded-full bg-white/15 hover:bg-white/25 flex items-center justify-center transition flex-shrink-0">
                                        <svg id="icon-play" class="w-4 h-4 text-white mr-[-1px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                        <svg id="icon-pause" class="w-4 h-4 text-white hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                                    </button>
                                    <div class="flex-1 h-1.5 bg-white/15 rounded-full overflow-hidden cursor-pointer" id="playback-bar" onclick="seekAudio(event)">
                                        <div id="playback-progress" class="h-full bg-brand-green rounded-full transition-all duration-100" style="width:0%"></div>
                                    </div>
                                    <span id="playback-time" class="text-white/50 text-[10px] font-mono tabular-nums w-8 text-left">0:00</span>
                                </div>
                            </div>
                            <!-- Re-record -->
                            <button type="button" onclick="resetRecorder()"
                                class="text-white/40 text-[11px] hover:text-white/70 transition flex items-center gap-1.5 mt-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                إعادة التسجيل
                            </button>
                            <audio id="audio-player" class="hidden"></audio>
                        </div>
                    </div>

                    <!-- Optional caption -->
                    <div class="mt-4">
                        <label class="block text-xs font-medium text-gray-500 mb-1">نص مرافق <span class="text-gray-400 font-normal">(اختياري)</span></label>
                        <div id="messages-list-voice" class="space-y-3">
                            <% let voiceMsgs=[{ text: '' , weight: '3' }]; if (campaign && campaign.message_templates) { try { voiceMsgs=JSON.parse(campaign.message_templates); } catch(e) {} } %>
                            <% voiceMsgs.forEach(function(m, i) { %>
                            <div class="message-box-voice bg-gray-50/80 px-4 py-3 rounded-xl border border-gray-100 hover:border-brand-green transition">
                                <textarea name="message_voice[]" rows="2" placeholder="حياك الله يا [الاسم] 🎙️"
                                    class="w-full bg-transparent border-none text-sm focus:ring-0 resize-none outline-none text-gray-700 placeholder-gray-300"><%= m.text %></textarea>
                            </div>
                            <% }) %>
                        </div>
                        <p class="text-[10px] text-gray-400 mt-1.5">يمكنك استخدام <code class="bg-gray-100 px-1 py-0.5 rounded">[الاسم]</code> هنا</p>
                    </div>
                </div><!-- end #content-voice -->
            </div><!-- end card -->

            <!-- Scheduling Section (Step 3) -->
            <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h3 class="text-sm font-semibold text-gray-800 mb-4 flex items-center gap-2">
                    <span class="w-6 h-6 bg-brand-light rounded flex items-center justify-center text-brand-dark">3</span>
                    توقيت الإرسال
                    <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded mr-2">قريباً 🚀</span>
                </h3>
                <div class="space-y-4 opacity-50 pointer-events-none">
                    <div class="flex gap-1 p-1 bg-gray-100 rounded-xl">
                        <button type="button" id="schedule-immediate" onclick="setScheduleMode('immediate')" disabled
                            class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 bg-white text-brand-dark shadow-sm">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            إرسال فوري
                        </button>
                        <button type="button" id="schedule-later" onclick="setScheduleMode('later')" disabled
                            class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 text-gray-500 hover:text-gray-700">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            جدولة لوقت لاحق
                        </button>
                    </div>
                    <div id="schedule-datetime-wrap" class="hidden grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1.5">التاريخ</label>
                            <input type="date" id="schedule-date" disabled
                                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 transition">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 mb-1.5">الوقت</label>
                            <input type="time" id="schedule-time" disabled
                                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-brand-green focus:ring-2 focus:ring-brand-green/10 transition">
                        </div>
                    </div>
                    <p id="schedule-hint" class="text-[10px] text-gray-400 hidden">
                        سيتم إرسال الحملة تلقائياً في الوقت المحدد (توقيت الرياض).
                    </p>
                </div>
            </div>

            <!-- Action Footer -->
            <div class="flex items-center justify-between pt-4">
                <button type="button" onclick="window.history.back()"
                    class="text-gray-400 text-sm hover:text-gray-600">إلغاء</button>
                <button type="submit" id="save-btn"
                    class="bg-brand-dark text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">
                    <%= campaign ? 'حفظ التعديلات' : 'إنشاء الحملة 🚀' %>
                </button>
            </div>
        </div>

        <!-- Left Col: Editor (5 cols) -->
        <div class="lg:col-span-5 space-y-6">
            <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm sticky top-24 relative">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-semibold text-gray-800">المصمم الذكي</h3>
                    <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded ml-2">قريباً 🚀</span>
                </div>
                <p class="text-[11px] text-gray-400 mb-4 text-center">ارفع الصورة ثم اسحب "الاسم" للمكان المناسب</p>

                <div id="canvas-container"
                    class="aspect-[4/5] bg-gray-50 rounded-xl border-2 border-dashed border-gray-200 flex flex-col items-center justify-center overflow-hidden relative opacity-50 pointer-events-none">
                    <p id="placeholder-text" class="text-xs text-gray-300">في انتظار رفع الصورة...</p>
                    <canvas id="previewCanvas" class="max-w-full max-h-full cursor-move shadow-md hidden"></canvas>
                </div>

                <!-- Canvas Controls -->
                <div id="canvas-controls" class="grid grid-cols-2 gap-4 mt-4 opacity-50 pointer-events-none">
                    <div>
                        <label class="block text-[10px] font-medium text-gray-500 mb-1">حجم الخط</label>
                        <% let cfgFontSize=60; let cfgFontColor='#000000' ; if (campaign && campaign.canvas_config) {
                            try { const cc=JSON.parse(campaign.canvas_config); cfgFontSize=cc.fontSize || 60;
                            cfgFontColor=cc.color || '#000000' ; } catch(e) {} } %>
                            <input type="number" id="fontSize" value="<%= cfgFontSize %>"
                                class="w-full px-3 py-1.5 rounded-lg border border-gray-200 text-sm" disabled>
                    </div>
                    <div>
                        <label class="block text-[10px] font-medium text-gray-500 mb-1">اللون</label>
                        <input type="color" id="fontColor" value="<%= cfgFontColor %>"
                            class="w-full h-8 p-0 rounded-lg border border-gray-200 cursor-pointer overflow-hidden" disabled>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

<script>
// ── Content type tab switching ─────────────────────────────────────
function switchTab(tab) {
    const isVoice = tab === 'voice';

    document.getElementById('content-text').classList.toggle('hidden', isVoice);
    document.getElementById('content-voice').classList.toggle('hidden', !isVoice);

    const tabText = document.getElementById('tab-text');
    const tabVoice = document.getElementById('tab-voice');

    if (isVoice) {
        tabVoice.classList.add('bg-white', 'text-brand-dark', 'shadow-sm');
        tabVoice.classList.remove('text-gray-500', 'hover:text-gray-700');
        tabText.classList.remove('bg-white', 'text-brand-dark', 'shadow-sm');
        tabText.classList.add('text-gray-500', 'hover:text-gray-700');
    } else {
        tabText.classList.add('bg-white', 'text-brand-dark', 'shadow-sm');
        tabText.classList.remove('text-gray-500', 'hover:text-gray-700');
        tabVoice.classList.remove('bg-white', 'text-brand-dark', 'shadow-sm');
        tabVoice.classList.add('text-gray-500', 'hover:text-gray-700');
    }

    // Notify campaign-editor about current mode
    window.CAMPAIGN_MODE = tab;
}

// ── Voice Recorder State Machine ──────────────────────────────────
let _mediaRecorder = null;
let _audioChunks = [];
let _audioBlob = null;
let _audioUrl = null;
let _recTimerInterval = null;
let _recSeconds = 0;
let _analyserAnimId = null;
let _audioCtxRec = null;
let _analyserNode = null;
let _recordedFile = null; // File object exposed to campaign-editor.js

function _showVrState(state) {
    ['vr-idle', 'vr-recording', 'vr-recorded'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            if (id === state) {
                el.classList.remove('hidden');
                el.classList.add('flex');
            } else {
                el.classList.add('hidden');
                el.classList.remove('flex');
            }
        }
    });
}

function _formatTime(secs) {
    const m = Math.floor(secs / 60).toString().padStart(2, '0');
    const s = (secs % 60).toString().padStart(2, '0');
    return m + ':' + s;
}

function _startWaveform(stream) {
    const canvas = document.getElementById('waveform-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    _audioCtxRec = new (window.AudioContext || window.webkitAudioContext)();
    const source = _audioCtxRec.createMediaStreamSource(stream);
    _analyserNode = _audioCtxRec.createAnalyser();
    _analyserNode.fftSize = 128;
    source.connect(_analyserNode);
    const bufLen = _analyserNode.frequencyBinCount;
    const dataArr = new Uint8Array(bufLen);

    function draw() {
        _analyserAnimId = requestAnimationFrame(draw);
        _analyserNode.getByteFrequencyData(dataArr);
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const barW = (canvas.width / bufLen) * 2;
        let x = 0;
        for (let i = 0; i < bufLen; i++) {
            const h = (dataArr[i] / 255) * canvas.height;
            const alpha = 0.4 + (dataArr[i] / 255) * 0.6;
            ctx.fillStyle = `rgba(0, 200, 83, ${alpha})`;
            ctx.beginPath();
            ctx.roundRect(x, canvas.height - h, barW - 1, h, 2);
            ctx.fill();
            x += barW;
        }
    }
    draw();
}

function _stopWaveform() {
    if (_analyserAnimId) { cancelAnimationFrame(_analyserAnimId); _analyserAnimId = null; }
    if (_audioCtxRec) { _audioCtxRec.close().catch(() => {}); _audioCtxRec = null; }
    const canvas = document.getElementById('waveform-canvas');
    if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
}

function _bindPlayerEvents() {
    const player = document.getElementById('audio-player');
    if (!player) return;
    player.ontimeupdate = function () {
        if (!player.duration) return;
        const pct = (player.currentTime / player.duration) * 100;
        const el = document.getElementById('playback-progress');
        if (el) el.style.width = pct + '%';
        const secs = Math.floor(player.currentTime);
        const t = document.getElementById('playback-time');
        if (t) t.textContent = _formatTime(secs);
    };
    player.onended = function () {
        const ip = document.getElementById('icon-play');
        const pause = document.getElementById('icon-pause');
        if (ip) ip.classList.remove('hidden');
        if (pause) pause.classList.add('hidden');
        const pp = document.getElementById('playback-progress');
        if (pp) pp.style.width = '0%';
        const t = document.getElementById('playback-time');
        if (t) t.textContent = '0:00';
    };
}

function startRecording() {
    navigator.mediaDevices.getUserMedia({ audio: true })
        .then(function (stream) {
            _audioChunks = [];
            _recSeconds = 0;
            document.getElementById('rec-timer').textContent = '00:00';
            _showVrState('vr-recording');
            _startWaveform(stream);

            _recTimerInterval = setInterval(function () {
                _recSeconds++;
                document.getElementById('rec-timer').textContent = _formatTime(_recSeconds);
            }, 1000);

            const mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
                ? 'audio/webm;codecs=opus'
                : (MediaRecorder.isTypeSupported('audio/ogg') ? 'audio/ogg' : 'audio/webm');

            _mediaRecorder = new MediaRecorder(stream, { mimeType });
            _mediaRecorder.ondataavailable = function (e) {
                if (e.data && e.data.size > 0) _audioChunks.push(e.data);
            };
            _mediaRecorder.onstop = function () {
                stream.getTracks().forEach(t => t.stop());
                _stopWaveform();
                clearInterval(_recTimerInterval);

                const ext = mimeType.includes('ogg') ? 'ogg' : 'webm';
                _audioBlob = new Blob(_audioChunks, { type: mimeType });
                _audioUrl = URL.createObjectURL(_audioBlob);
                _recordedFile = new File([_audioBlob], 'voice-note.' + ext, { type: mimeType });

                // Inject into the hidden file input so campaign-editor.js picks it up
                const dt = new DataTransfer();
                dt.items.add(_recordedFile);
                document.getElementById('voicenoteUpload').files = dt.files;

                const player = document.getElementById('audio-player');
                player.src = _audioUrl;
                _bindPlayerEvents();
                player.onloadedmetadata = function () {
                    const dur = document.getElementById('rec-final-duration');
                    if (dur) dur.textContent = _formatTime(Math.round(player.duration));
                };

                _showVrState('vr-recorded');
            };

            _mediaRecorder.start(100);
        })
        .catch(function (err) {
            console.error('Mic error:', err);
            alert('تعذّر الوصول إلى الميكروفون. تأكد من منح الإذن.');
        });
}

function stopRecording() {
    if (_mediaRecorder && _mediaRecorder.state !== 'inactive') {
        _mediaRecorder.stop();
    }
}

function togglePlayback() {
    const player = document.getElementById('audio-player');
    if (!player || !player.src) return;
    const ip = document.getElementById('icon-play');
    const pause = document.getElementById('icon-pause');
    if (player.paused) {
        player.play();
        if (ip) ip.classList.add('hidden');
        if (pause) pause.classList.remove('hidden');
    } else {
        player.pause();
        if (ip) ip.classList.remove('hidden');
        if (pause) pause.classList.add('hidden');
    }
}

function seekAudio(e) {
    const player = document.getElementById('audio-player');
    const bar = document.getElementById('playback-bar');
    if (!player || !bar || !player.duration) return;
    const rect = bar.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    player.currentTime = pct * player.duration;
}

function resetRecorder() {
    const player = document.getElementById('audio-player');
    if (player) { player.pause(); player.src = ''; }
    _audioBlob = null;
    _audioUrl = null;
    _recordedFile = null;
    const dt = new DataTransfer();
    document.getElementById('voicenoteUpload').files = dt.files;
    _showVrState('vr-idle');
}

// ── File upload fallback ────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
    // Auto-switch to voice tab if campaign already has a voicenote
    <% if (campaign && campaign.voicenote_path) { %>
    switchTab('voice');
    <% } %>

    const vnInput = document.getElementById('voicenoteUpload');
    if (vnInput) {
        vnInput.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            _recordedFile = file;
            _audioUrl = URL.createObjectURL(file);
            const player = document.getElementById('audio-player');
            player.src = _audioUrl;
            _bindPlayerEvents();
            player.onloadedmetadata = function () {
                const dur = document.getElementById('rec-final-duration');
                if (dur) dur.textContent = _formatTime(Math.round(player.duration));
            };
            const durEl = document.getElementById('rec-final-duration');
            if (durEl) durEl.textContent = file.name;
            _showVrState('vr-recorded');
        });
    }
});

// Expose active mode for campaign-editor.js
window.CAMPAIGN_MODE = 'text';

// ── Schedule Toggle ──────────────────────────────────────────────────
window.CAMPAIGN_SCHEDULE_MODE = 'immediate';

function setScheduleMode(mode) {
    window.CAMPAIGN_SCHEDULE_MODE = mode;
    const isLater = mode === 'later';
    document.getElementById('schedule-datetime-wrap').classList.toggle('hidden', !isLater);
    document.getElementById('schedule-datetime-wrap').classList.toggle('grid', isLater);
    document.getElementById('schedule-hint').classList.toggle('hidden', !isLater);

    const btnImm = document.getElementById('schedule-immediate');
    const btnLater = document.getElementById('schedule-later');
    if (isLater) {
        btnLater.classList.add('bg-white', 'text-brand-dark', 'shadow-sm');
        btnLater.classList.remove('text-gray-500', 'hover:text-gray-700');
        btnImm.classList.remove('bg-white', 'text-brand-dark', 'shadow-sm');
        btnImm.classList.add('text-gray-500', 'hover:text-gray-700');
    } else {
        btnImm.classList.add('bg-white', 'text-brand-dark', 'shadow-sm');
        btnImm.classList.remove('text-gray-500', 'hover:text-gray-700');
        btnLater.classList.remove('bg-white', 'text-brand-dark', 'shadow-sm');
        btnLater.classList.add('text-gray-500', 'hover:text-gray-700');
    }
}

document.addEventListener('DOMContentLoaded', function () {
    <% if (campaign && campaign.scheduled_at) { %>
    setScheduleMode('later');
    const sd = new Date('<%= new Date(campaign.scheduled_at).toISOString() %>');
    const sdYear = sd.getFullYear();
    const sdMonth = String(sd.getMonth() + 1).padStart(2, '0');
    const sdDay = String(sd.getDate()).padStart(2, '0');
    const sdHours = String(sd.getHours()).padStart(2, '0');
    const sdMins = String(sd.getMinutes()).padStart(2, '0');
    document.getElementById('schedule-date').value = sdYear + '-' + sdMonth + '-' + sdDay;
    document.getElementById('schedule-time').value = sdHours + ':' + sdMins;
    <% } %>
});
</script>

