<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %>أوتو إنفايت</title>
  <meta name="description" content="منصة دعوات الواتساب الذكية">

  <!-- TSNAS Bold Font -->
  <style>
    @font-face {
      font-family: 'TSNAS Bold';
      src: url('/assets/fonts/TSNAS-BOLD.OTF') format('opentype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
  </style>

  <!-- Tailwind CSS (compiled locally) -->
  <link rel="stylesheet" href="/css/tailwind.css">

  <!-- Chart.js (Conditional) -->
  <% if (typeof activePage !== 'undefined' && activePage === 'dashboard') { %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <% } %>

  <!-- Socket.IO (only loaded when needed) -->
  <% if (typeof useSocket !== 'undefined' && useSocket) { %>
  <script src="/socket.io/socket.io.js"></script>
  <% } %>

  <style>
    * { box-sizing: border-box; }
    body { font-family: 'TSNAS Bold', sans-serif; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: #F7F8FA; }
    ::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: #9CA3AF; }

    /* Sidebar active state */
    .nav-item.active {
      background-color: #E8FAF0;
      color: #0A3D2E;
      font-weight: 600;
      border-right: 3px solid #00C853;
    }
    .nav-item { transition: all 0.15s ease; }
    .nav-item:hover:not(.active) { background-color: #F7F8FA; }

    /* Status badge pulse */
    @keyframes pulse-green {
      0%, 100% { box-shadow: 0 0 0 0 rgba(0, 200, 83, 0.4); }
      50% { box-shadow: 0 0 0 6px rgba(0, 200, 83, 0); }
    }
    .status-pulse { animation: pulse-green 2s infinite; }

    /* Page fade-in */
    .page-content { animation: fadeIn 0.25s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

    /* Toast */
    #toast-container { position: fixed; top: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }

    /* Logs panel */
    #logs-area {
      height: 280px; overflow-y: auto;
      background: #0f172a; border-radius: 10px;
      padding: 1rem; font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; line-height: 1.6;
    }
    .log-SUCCESS { color: #00C853; font-weight: 600; }
    .log-ERROR { color: #ef4444; font-weight: 600; }
    .log-WARN { color: #fbbf24; }
    .log-INFO { color: #94a3b8; }
    .log-DONE { color: #fff; background: #00C853; padding: 2px 8px; border-radius: 4px; }

    /* Responsive adjustments */
    @media (max-width: 1024px) {
      .flex-1 { margin-right: 0 !important; }
      aside { display: none; } /* Use a mobile drawer in the future */
    }
  </style>

  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>

<body class="bg-surface-gray text-gray-800 min-h-screen">

<!-- Toast Container -->
<div id="toast-container"></div>

<% 
var _subStatus = typeof subscriptionStatus !== 'undefined' ? subscriptionStatus : 'trialing';
var _subPlan = typeof subscriptionPlan !== 'undefined' ? subscriptionPlan : 'free';
var _trialEnd = typeof trialEndsAt !== 'undefined' ? trialEndsAt : null;
var _showBanner = false;
var _bannerMsg = '';
var _bannerType = 'amber';

if (_subStatus === 'trialing' && _trialEnd) {
    var _daysLeft = Math.ceil((new Date(_trialEnd) - new Date()) / (1000 * 60 * 60 * 24));
    if (_daysLeft > 0) {
        _showBanner = true;
        _bannerMsg = 'الفترة التجريبية — متبقي ' + _daysLeft + ' يوم';
        _bannerType = 'amber';
    } else {
        _showBanner = true;
        _bannerMsg = 'انتهت الفترة التجريبية — اشترك الآن للاستمرار';
        _bannerType = 'red';
    }
} else if (_subStatus === 'past_due') {
    _showBanner = true;
    _bannerMsg = 'يوجد مشكلة في الدفع — يرجى تحديث بيانات الدفع';
    _bannerType = 'red';
}
%>
<% if (_showBanner) { %>
<div id="trial-banner" class="<%= _bannerType === 'red' ? 'bg-red-50 border-red-200 text-red-700' : 'bg-amber-50 border-amber-200 text-amber-700' %> border-b px-6 py-2 flex items-center justify-between text-sm">
  <div class="flex items-center gap-2">
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
    <span><%= _bannerMsg %></span>
  </div>
  <a href="/billing"
     class="inline-flex items-center gap-1.5 bg-brand-dark text-white text-xs px-3 py-1.5 rounded-lg font-medium hover:opacity-90 transition">
    إدارة الاشتراك
  </a>
</div>
<% } %>

<!-- App Shell -->
<div class="flex min-h-screen">

  <!-- ====== SIDEBAR (Right in RTL) ====== -->
  <%- include('../partials/sidebar') %>

  <!-- ====== MAIN AREA ====== -->
  <div class="flex-1 flex flex-col min-h-screen" style="margin-right: 224px;">

    <!-- ====== TOP BAR ====== -->
    <%- include('../partials/topbar') %>

    <!-- ====== PAGE CONTENT ====== -->
    <main class="flex-1 p-6 page-content">
      <%- body %>
    </main>

  </div>
</div>

<!-- Global JS Utilities -->
<script>
// Premium Toast Notification System
function showToast(type, message) {
  const container = document.getElementById('toast-container');
  if (!container) return;
  const icons = {
    success: '<svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    error: '<svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    warning: '<svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
    info: '<svg class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
  };
  const borders = { success: 'border-green-200', error: 'border-red-200', warning: 'border-amber-200', info: 'border-blue-200' };
  const toast = document.createElement('div');
  toast.className = `flex items-center gap-3 bg-white border ${borders[type] || 'border-gray-200'} rounded-xl px-4 py-3 shadow-xl text-sm text-gray-700 font-medium max-w-sm`;
  toast.style.animation = 'toastSlideIn 0.35s cubic-bezier(0.16,1,0.3,1)';
  toast.innerHTML = `${icons[type] || icons.info}<span>${message}</span>`;
  container.appendChild(toast);
  setTimeout(() => { toast.style.animation = 'toastSlideOut 0.3s ease forwards'; setTimeout(() => toast.remove(), 300); }, 4000);
}
</script>

<style>
@keyframes toastSlideIn { from { transform: translateY(100%) scale(0.95); opacity: 0; } to { transform: translateY(0) scale(1); opacity: 1; } }
@keyframes toastSlideOut { from { transform: translateY(0) scale(1); opacity: 1; } to { transform: translateY(100%) scale(0.95); opacity: 0; } }
</style>

<%- typeof extraScript !== 'undefined' ? extraScript : '' %>
</body>
</html>
