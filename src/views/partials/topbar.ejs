<!-- TOP BAR -->
<header class="sticky top-0 z-30 bg-white border-b border-gray-200 px-6 py-3.5 flex items-center justify-between"
    style="box-shadow: 0 1px 4px rgba(0,0,0,0.04);">

    <!-- Right: Page Title + Subtitle -->
    <div class="flex items-center gap-3">
        <% if (typeof breadcrumb !=='undefined' ) { %>
            <a href="<%= breadcrumb.href %>" class="text-gray-400 hover:text-gray-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
            </a>
            <% } %>
                <div>
                    <h1 class="text-base font-semibold text-gray-900 leading-tight">
                        <%= typeof pageTitle !=='undefined' ? pageTitle : 'لوحة التحكم' %>
                    </h1>
                    <% if (typeof pageSubtitle !=='undefined' ) { %>
                        <p class="text-xs text-gray-400 mt-0.5 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                    clip-rule="evenodd" />
                            </svg>
                            <%= pageSubtitle %>
                        </p>
                        <% } %>
                </div>
    </div>

    <!-- Left: Actions + Status -->
    <div class="flex items-center gap-2">

        <!-- WhatsApp Status Indicator -->
        <div id="wa-status-badge" class="flex items-center gap-1.5 text-xs px-2.5 py-1.5 rounded-lg border">
            <span id="wa-status-dot" class="w-2 h-2 rounded-full bg-gray-300"></span>
            <span id="wa-status-text" class="text-gray-500 font-medium">الواتساب</span>
        </div>

        <!-- Page Action Buttons (injected by child via topbarActions variable) -->
        <% if (typeof topbarActions !=='undefined' ) { %>
            <%- topbarActions %>
                <% } %>

    </div>
</header>