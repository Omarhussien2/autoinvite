<!-- SIDEBAR -->
<aside
    class="fixed top-0 right-0 h-full w-60 bg-white border-l border-gray-100 flex flex-col z-40 transition-all duration-300 shadow-[2px_0_20px_rgba(0,0,0,0.02)]">

    <!-- Logo -->
    <div class="flex items-center gap-2.5 px-6 py-8 mb-4">
        <img src="/assets/images/logo-new.png" alt="أوتو إنفايت" class="w-9 h-9 object-contain flex-shrink-0">
        <div class="flex flex-col">
            <div class="flex items-center">
                <span class="font-bold text-gray-900 text-lg tracking-tight">أوتو</span>
                <span class="font-bold text-brand-green text-lg tracking-tight"> إنفايت</span>
            </div>
            <span class="text-[10px] text-gray-400 font-medium -mt-1 uppercase tracking-widest">SaaS Edition</span>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-4 space-y-1 overflow-y-auto custom-scrollbar">
        <a href="/dashboard"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'dashboard' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>لوحة التحكم</span>
        </a>

        <a href="/campaigns"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'campaigns' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
            </svg>
            <span>الحملات</span>
        </a>

        <a href="/inbox"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'inbox' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
            <span>صندوق الردود</span>
            <span id="inbox-badge" class="mr-auto text-[10px] font-bold text-white bg-red-500 px-1.5 py-0.5 rounded-full hidden">0</span>
        </a>

        <a href="/contacts"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'contacts' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>جهات الاتصال</span>
        </a>

        <a href="/reports"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'reports' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span>التقارير</span>
        </a>

        <div class="h-px bg-gray-50 mx-4 my-4"></div>

        <a href="/campaigns"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'campaigns' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>الجدولة الذكية</span>
        </a>

        <% if (typeof tenantRole !== 'undefined' && tenantRole === 'admin') { %>
        <div class="h-px bg-gray-50 mx-4 my-4"></div>
        <a href="/admin/dashboard"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'admin' ? 'bg-red-50 text-red-700' : 'text-gray-500 hover:bg-red-50 hover:text-red-600' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span>لوحة المشرف</span>
        </a>
        <% } %>

        <div class="h-px bg-gray-50 mx-4 my-4"></div>

        <a href="/billing"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'billing' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <span>الاشتراك</span>
            <% 
            var _planKey = typeof subscriptionPlan !== 'undefined' ? subscriptionPlan : 'free';
            var _planBadge = { free: { label: 'مجاني', cls: 'bg-gray-100 text-gray-500' }, basic: { label: 'أساسي', cls: 'bg-blue-100 text-blue-700' }, pro: { label: 'احترافي', cls: 'bg-green-100 text-green-700' }, enterprise: { label: 'مؤسسات', cls: 'bg-purple-100 text-purple-700' } };
            var _pb = _planBadge[_planKey] || _planBadge.free;
            %>
            <span class="mr-auto text-[10px] font-bold px-2 py-0.5 rounded-full <%= _pb.cls %>"><%= _pb.label %></span>
        </a>

        <a href="/settings"
            class="group flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium transition-all duration-200 <%= activePage === 'settings' ? 'bg-brand-light text-brand-dark' : 'text-gray-500 hover:bg-gray-50 hover:text-brand-green' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>الإعدادات</span>
        </a>
    </nav>

    <!-- User Section -->
    <div class="p-4 border-t border-gray-50">
        <div class="flex items-center gap-3 p-2 rounded-2xl bg-gray-50/50 border border-gray-100/50">
            <div
                class="w-10 h-10 rounded-xl bg-brand-dark flex items-center justify-center flex-shrink-0 text-white font-bold text-lg shadow-sm">
                <%= typeof tenantName !=='undefined' ? tenantName.charAt(0).toUpperCase() : 'U' %>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-gray-900 truncate">
                    <%= typeof tenantName !=='undefined' ? tenantName : 'المستخدم' %>
                </p>
                <button onclick="handleLogout()"
                    class="text-[10px] font-medium text-gray-400 hover:text-red-500 transition">تسجيل الخروج</button>
            </div>
        </div>
    </div>

</aside>

<script>
    async function handleLogout() {
        if (!confirm('هل تريد تسجيل الخروج؟')) return;
        try {
            const res = await fetch('/auth/logout', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                window.location.href = data.redirect;
            }
        } catch (e) { console.error('Logout failed', e); }
    }
</script>